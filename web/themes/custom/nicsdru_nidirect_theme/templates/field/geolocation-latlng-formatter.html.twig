{#
/**
 * @file
 * Overrides default geolocation latitude / longitude formatter with Google map iframe embed.
 *
 * Available variables:
 * - lat: The latitude value.
 * - lng: The longitude value.
 *
 * @see template_preprocess()
 *
 * @ingroup themeable
 */
#}
<iframe
  loading="lazy"
  width="100%"
  height="400"
  style="border:0"
  referrerpolicy="no-referrer-when-downgrade"
  title="Map showing location of this contact"
  src="https://www.google.com/maps?q={{ lat }},{{ lng }}&z=13&output=embed">
</iframe>

<p>
  <a href="https://maps.google.com/?q={{ lat }},{{ lng }}">
    Open this location in Google Maps
  </a>
</p>
