<?php

/**
 * @file
 * Contains nidirect_prisons.module.
 */

use Drupal\Core\Database\Database;
use Drupal\nidirect_prisons\Service\PrisonerPaymentManager;

/**
 * Implements hook_cron().
 */
function nidirect_prisons_cron() {

  /** @var \Drupal\nidirect_prisons\Service\PrisonerPaymentManager $payment_manager */
  $payment_manager = \Drupal::service('nidirect_prisons.prisoner_payment_manager');

  /**
   * Mark pending transactions older than SOFT_TIMEOUT/HARD_TIMEOUT as
   * expired and send a Worldpay cancel request.
   */

  $now = \Drupal::time()->getRequestTime();

  // Pull timeouts from PrisonerPaymentManager constants.
  $hard_timeout = PrisonerPaymentManager::HARD_TIMEOUT;
  $soft_timeout = PrisonerPaymentManager::SOFT_TIMEOUT;

  // Get all pending transactions.
  $pending_transactions = $payment_manager->getPendingTransactions();

  if ($pending_transactions) {

    foreach ($pending_transactions as $transaction) {
      $hard_expired = ($transaction->created_timestamp < ($now - $hard_timeout));
      $soft_expired = ($transaction->updated_timestamp < ($now - $soft_timeout));

      if (!$hard_expired && !$soft_expired) {
        continue;
      }

      // Expire transaction.
      $payment_manager->updateTransactionStatus($transaction->order_key, 'expired');

      // Cancel Worldpay order.
      try {
        $prison_id = $payment_manager->getPrisonId($transaction->prisoner_id);
        $payment_manager->cancelWorldpayOrder($transaction->order_key, $prison_id);
      }
      catch (\Throwable $e) {
        \Drupal::logger('nidirect_prisons')->error(
          'Cron failed cancelling Worldpay order @order: @message',
          [
            '@order' => $transaction->order_key,
            '@message' => $e->getMessage(),
          ]
        );
      }
    }
  }

  /**
   * Delete all transactions more than 7 days old.
   */

  $connection = Database::getConnection();
  $threshold = strtotime('-7 days');
  $query = $connection->delete('prisoner_payment_transactions')
    ->condition('created_timestamp', $threshold, '<');
  $deleted = $query->execute();

  if ($deleted) {
    \Drupal::logger('nidirect_prisons')->info('Deleted @count old prisoner payment transactions.', ['@count' => $deleted]);
  }
}

/**
 * Implements hook_mail().
 */
function nidirect_prisons_mail($key, &$message, $params) {
  switch ($key) {
    case 'prisoner_payment_notification':
      $message['subject'] = $params['subject'];
      $message['body'] = is_array($params['body']) ? $params['body'] : [$params['body']];
      $message['headers']['Content-Type'] = 'text/plain; charset=UTF-8';

      \Drupal::logger('nidirect_prisons')->notice('Email subject: @subject, body: @body', [
        '@subject' => $message['subject'],
        '@body' => implode("\n", $message['body']),
      ]);

      break;
  }
}
